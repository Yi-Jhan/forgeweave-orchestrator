{
  "name": "forgeweave-orchestrator",
  "version": "0.0.0",
  "private": true,
  "description": "CLI-first runtime-agnostic multi-agent orchestration toolkit.",
  "license": "UNLICENSED",
  "packageManager": "pnpm@7.27.1",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "test": "vitest run --passWithNoTests",
    "test:unit": "vitest run --passWithNoTests",
    "test:contract": "vitest run packages/contracts/src/schemas/base-contract.test.ts",
    "test:cli": "vitest run apps/cli/src/cli.test.ts",
    "test:smoke": "pnpm --filter @forgeweave/cli build && pnpm --filter @forgeweave/cli smoke"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
