# ForgeWeave Orchestrator 本機環境設定範例
# 請複製成 .env.local 後填入每個工作環境自己的路徑。
# 不要把 .env.local commit 進 repo。

# 外部 ACC repo 位置。Phase 1 live-readonly、Phase 2 live-readonly、Phase 4 live-patch 驗證才需要。
FORGEWEAVE_ACC_ROOT=

# 第二參考專案位置。若未設定，使用 examples/minimal-project fixture。
FORGEWEAVE_SECOND_PROJECT_ROOT=

# fixture | live-readonly | live-patch
# 預設 fixture：不需要真實 ACC repo。
FORGEWEAVE_VALIDATION_MODE=fixture

# 是否允許 ForgeWeave 對外部專案寫入 patch。
# Phase 4 live migration 時才應設為 true，且必須使用隔離 branch/worktree。
FORGEWEAVE_ALLOW_EXTERNAL_PATCH=false
